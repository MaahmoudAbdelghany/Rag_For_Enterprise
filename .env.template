# ==========================================
# Enterprise RAG Environment Configuration Template
# Copy this file to .env and fill in your actual secrets
# ==========================================

# Company / Application Settings
COMPANY_NAME="FinSolve Technologies"
APP_ENV="development"
LOG_LEVEL="INFO"

# LLM Provider Configuration (Groq for dev / Azure OpenAI for prod)
LLM_PROVIDER="groq"
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.1-70b-versatile"

# Optional: Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT_NAME=""

# Vector Store Configuration (Qdrant)
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION_NAME="enterprise_rag"

# Embedding Model Configuration
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"

# Guardrails & PII Settings
PII_ANONYMIZATION_ENABLED=true
PII_ENTITIES=["PERSON", "EMAIL_ADDRESS", "PHONE_NUMBER", "US_SSN", "CREDIT_CARD"]

# Monitoring & Observability (LangSmith)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="your_langsmith_api_key_here"
LANGSMITH_PROJECT="enterprise-rag-chatbot"
